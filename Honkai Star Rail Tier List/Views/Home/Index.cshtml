@{
    ViewData["Title"] = "Home Page";
    @model List<Honkai_Star_Rail_Tier_List.Models.Character>

    var tiers = new[] { "S", "A", "B", "F" };
    var roles = new[] { "DPS", "Sub-DPS", "Support", "Sustain" };
}

<h1>
    Honkai: Star Rail Tier List
</h1>

<div></div>

<button class="accordion">About the tier list</button>
    <div class="panel">
        <p>This tier list ranks each charcter based on his or her performance in each of the different end game modes</p>
    </div>

<button class="accordion">Catagories</button>
    <div class="panel">
        <ul>
            <li>
                DPS - DPS is the main damage dealer of the team. Their goals are to defeat the enemy.
            </li>
            <li>
                Sub-DPS - A secondary damage dealer, that typically doesn't deal as much damage as a proper DPS, but can make up for it by also providing a bit of support to other team members.
            </li>
            <li>
                Support - Supports are there to help the team by buffing other team members or debuffing enemies.
            </li>
            <li>
                Sustain - Sustain units keep their teammates alive. This is done by either healing or providing the team with shields.
            </li>
        </ul>
    </div>

<button class="accordion">Changes </button>
    <div class="panel">
        <p>Below is a list of recent changes to a characthers rating and an explanation</p>
    </div>

<div class="mode-buttons">
    <button class="mode-btn" data-mode="as">Apocalyptic Shadow</button>
    <button class="mode-btn" data-mode="moc">Memory of Chaos</button>
    <button class="mode-btn" data-mode="pf">Pure Fiction</button>
</div>

@foreach (var character in Model)
{
    <div class="character-card"
         data-role="@character.Role"
         data-as="@character.TierAS"
         data-moc="@character.TierMOC"
         data-pf="@character.TierPF">

        <a asp-controller="Character" asp-action="Details" asp-route-name="@character.Name">
            <div class="character">
                <img src="/Images/@character.Image">
            </div>
        </a>

    </div>
}

<div class="tier-list">

    <!-- Role Headers -->
    <div class="role-header">
        <div></div>
        <div>DPS</div>
        <div>SubDPS</div>
        <div>Support</div>
        <div>Sustain</div>
    </div>

    <!--Create the table-->
    @foreach (var tier in tiers)
    {
        <div class="tier" data-tier="@tier">

            <div class="tier-row">

                <div class="tier-label @tier">@tier</div>

                @foreach (var role in roles)
                {
                    <div class="role-column" data-role="@role">
                        <div class="tier-container"></div>
                    </div>
                }

            </div>
        </div>
    }

</div>